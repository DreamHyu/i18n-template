{
  "name": "new-project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "node --experimental-test-isolation=none --test",
    "prepare": "husky",
    "sync:i18n": "node scripts/sync-i18n.mjs --mode working-tree",
